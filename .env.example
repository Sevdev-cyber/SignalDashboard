# Copy this file to `.env` on the VPS or local machine.
# Example on VPS:
#   C:\SignalDashboard\.env

# Required if you want real LLM calls:
OPENAI_API_KEY=
# Or alternatively:
# DEEPSEEK_API_KEY=

# Optional provider/model overrides:
SNAPSHOT_LLM_PROVIDER=openai
SNAPSHOT_LLM_MODEL=gpt-4.1-mini
# SNAPSHOT_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
SNAPSHOT_LLM_TIMEOUT_SEC=30

# Daily / intraday context toggles:
SIGNAL_DAILY_CONTEXT_ENABLED=1
SIGNAL_DAILY_CONTEXT_USE_LLM=1
SIGNAL_CONTEXT_REFRESH_HOURS=1

SIGNAL_INTRADAY_LLM_ENABLED=1
SIGNAL_INTRADAY_LLM_USE_API=1
SIGNAL_INTRADAY_LLM_BASE_MIN=15
SIGNAL_INTRADAY_LLM_EVENT_COOLDOWN_MIN=7
SIGNAL_INTRADAY_LLM_MAX_EVENTS_PER_HOUR=3
SIGNAL_INTRADAY_LLM_MIN_CONF_DELTA=12
SIGNAL_INTRADAY_LLM_MIN_L2_CONF=72

# Optional defaults for dashboard / server:
DASHBOARD_BAR_TF_MIN=1
SIGNAL_ENGINE_MODE=final_mtf_v3
NT_ACCOUNT_NAME=Playback101
